# Environment variables for Python service

# Database Configuration
# Local: single URL (Docker on Mac: use host.docker.internal instead of localhost).
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/archimedes
# ECS / RDS IAM auth: set USE_IAM_AUTH=true and the DB_* vars; leave DATABASE_URL unset.
# USE_IAM_AUTH=true
# DB_HOST=your-cluster.xxxx.us-west-2.rds.amazonaws.com
# DB_PORT=5432
# DB_NAME=archimedes
# DB_IAM_USER=your_iam_db_user
# Optional: path to AWS RDS CA bundle (default in Docker: /etc/ssl/rds/global-bundle.pem).
# RDS_SSL_CA_BUNDLE=/path/to/global-bundle.pem

# Server Configuration
PORT=8000
ENVIRONMENT=devxs

# S3 Configuration
S3_ACTIVITY_BUCKET_NAME=your-s3-exercises-bucket
S3_ACTIVITY_RESULTS_BUCKET_NAME=your-s3-results-bucket
# Base URL for activity content (miniquiz HTML). Activity content_url = {this}/{activity_id}.html. Change here if you move to CloudFront or another host; no code change needed. Alias: MINIQUIZ_BASE_URL.
S3_MINI_QUIZ_BASE_URL=https://your-s3-exercises-bucket.s3-website-us-west-2.amazonaws.com/

# AWS Cognito Configuration
AWS_REGION=us-west-2
COGNITO_USER_POOL_ID=us-west-2_qNjGNCmga
COGNITO_CLIENT_ID=6hsscghopiit077utabs2voc1e
# Hosted UI domain (required for Google sign-in). From Cognito: User Pool -> App integration -> Domain name.
# Format: <domain-prefix>.auth.<region>.amazoncognito.com (e.g. archimedes-dev.auth.us-west-2.amazoncognito.com)
COGNITO_DOMAIN=archimedes-dev-928483661641.auth.us-west-2.amazoncognito.com
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# Optional Cognito Configuration
COGNITO_USER_POOL_CLIENT_NAME=your-client-name
COGNITO_CLIENT_SECRET=your-client-secret
# Must match Cognito app client "Allowed callback URLs" exactly
OAUTH_CALLBACK_URI=http://localhost:8001/api/v1/auth/callback
# Frontend URL for OAuth callback redirect (custom auth UI). Backend redirects to {FRONTEND_URL}/auth/callback#access_token=...
FRONTEND_URL=http://localhost:3000
# Comma-separated CORS origins (no "*"). Defaults merge FRONTEND_URL + origin of S3_MINI_QUIZ_BASE_URL / MINIQUIZ_BASE_URL (so miniquiz CDN can fetch the API). Add both http and https CDN origins if you use both.
# CORS_ORIGINS=http://localhost:3000,http://d21jyw7vfrv0n9.cloudfront.net,https://d21jyw7vfrv0n9.cloudfront.net
COGNITO_ISSUER_URI=https://cognito-idp.us-west-2.amazonaws.com/your-cognito-user-pool-id
COGNITO_JWK_SET_URI=https://cognito-idp.us-west-2.amazonaws.com/your-cognito-user-pool-id/.well-known/jwks.json

### Teachers API - Archimedes Python Service
### Complete teacher management endpoints
### Base URL: http://localhost:8001

@baseUrl = http://localhost:8001
@apiVersion = /api/v1

###############################################################################
### 🧑‍🏫 TEACHER MANAGEMENT
###############################################################################

### Variables (Replace with actual values from responses)
@schoolId = 6f9fa83a-9b3e-4a54-a5ce-a4fd974e30cc
@teacherId = 660e8400-e29b-41d4-a716-446655440001
@accessToken = your_access_token_here

### 1. Create Teacher (Auto-creates default courses)
POST {{baseUrl}}{{apiVersion}}/teachers
Content-Type: application/json

{
  "first_name": "Sarah",
  "last_name": "Johnson",
  "email": "sarah.johnson@archimedesschool.edu",
  "username": "sarah.johnson",
  "school_id": "{{schoolId}}"
}

# Note: This automatically creates default courses (up to max_classes limit)
# Each course gets a unique join code for student enrollment

### 2. Get Teacher by ID
GET {{baseUrl}}{{apiVersion}}/teachers/{{teacherId}}

### 3. Get All Teachers (with pagination)
GET {{baseUrl}}{{apiVersion}}/teachers
    ?page=1
    &size=10

### 4. Get Teachers with Filters
GET {{baseUrl}}{{apiVersion}}/teachers
    ?school_id={{schoolId}}
    &department=Mathematics
    &subject=Algebra
    &page=1
    &size=10

### 5. Get Teachers by School
GET {{baseUrl}}{{apiVersion}}/teachers/school/{{schoolId}}
    ?page=1
    &size=10

### 6. Update Teacher
PUT {{baseUrl}}{{apiVersion}}/teachers/{{teacherId}}
Content-Type: application/json

{
  "first_name": "Sarah",
  "last_name": "Johnson-Smith",
  "email": "sarah.johnson-smith@archimedesschool.edu",
  "username": "sarah.johnson.smith",
  "max_classes": 8,
  "is_active": true
}

### 7. Update Teacher (Partial)
PUT {{baseUrl}}{{apiVersion}}/teachers/{{teacherId}}
Content-Type: application/json

{
  "max_classes": 10,
  "is_active": false
}

### 8. Delete Teacher
DELETE {{baseUrl}}{{apiVersion}}/teachers/{{teacherId}}

###############################################################################
### 🔍 SEARCH AND FILTER EXAMPLES
###############################################################################

### Search by Department
GET {{baseUrl}}{{apiVersion}}/teachers
    ?department=Science
    &page=1
    &size=20

### Search by Subject
GET {{baseUrl}}{{apiVersion}}/teachers
    ?subject=English
    &page=1
    &size=20

### Combined Filters
GET {{baseUrl}}{{apiVersion}}/teachers
    ?school_id={{schoolId}}
    &department=Mathematics
    &page=1
    &size=5


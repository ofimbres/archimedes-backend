# Environment variables for Python service

# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/archimedes

# Server Configuration
PORT=8000
ENVIRONMENT=devxs

# S3 Configuration
S3_ACTIVITY_BUCKET_NAME=dev-archimedes-exercises-bucket
S3_ACTIVITY_RESULTS_BUCKET_NAME=dev-archmimedes-exercise-results-bucket
S3_MINI_QUIZ_BASE_URL=https://dev-archimedes-exercises-bucket.s3-website-us-west-2.amazonaws.com/

# AWS Cognito Configuration
COGNITO_USER_POOL_ID=your-user-pool-id
COGNITO_USER_POOL_CLIENT_ID=your-client-id
COGNITO_USER_POOL_CLIENT_NAME=your-client-name
COGNITO_CLIENT_SECRET=your-client-secret
COGNITO_REDIRECT_URI=http://localhost:8000/auth/callback
COGNITO_ISSUER_URI=https://cognito-idp.us-west-2.amazonaws.com/your-user-pool-id
COGNITO_JWK_SET_URI=https://cognito-idp.us-west-2.amazonaws.com/your-user-pool-id/.well-known/jwks.json

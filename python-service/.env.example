# Environment variables for Python service

# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/archimedes

# Server Configuration
PORT=8000
ENVIRONMENT=devxs

# S3 Configuration
S3_ACTIVITY_BUCKET_NAME=your-s3-exercises-bucket
S3_ACTIVITY_RESULTS_BUCKET_NAME=your-s3-results-bucket
S3_MINI_QUIZ_BASE_URL=https://your-s3-exercises-bucket.s3-website-us-west-2.amazonaws.com/

# AWS Cognito Configuration
AWS_REGION=us-west-2
COGNITO_USER_POOL_ID=your-cognito-user-pool-id
COGNITO_CLIENT_ID=your-cognito-client-id
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# Optional Cognito Configuration
COGNITO_USER_POOL_CLIENT_NAME=your-client-name
COGNITO_CLIENT_SECRET=your-client-secret
COGNITO_REDIRECT_URI=http://localhost:8001/auth/callback
COGNITO_ISSUER_URI=https://cognito-idp.us-west-2.amazonaws.com/your-cognito-user-pool-id
COGNITO_JWK_SET_URI=https://cognito-idp.us-west-2.amazonaws.com/your-cognito-user-pool-id/.well-known/jwks.json

# ==========================================
# 🐍 Archimedes Python Service - Docker Ignore
# ==========================================
# Optimize Docker builds by excluding unnecessary files

# Git and version control
.git/
.github/
.gitignore
*.git*

# Python cache and compiled files
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
ENV/
env.bak/
venv.bak/
.venv/

# Development tools and configs
.pytest_cache/
.coverage
.mypy_cache/
.ruff_cache/
.tox/
pytest.ini
setup.cfg
pyproject.toml

# IDEs and editors
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Environment files (security)
.env
.env.*
!.env.example

# Documentation and development files
README*.md
docs/
*.md
LICENSE*

# Development containers
.devcontainer/
docker-compose*.yml
Dockerfile.dev

# API testing files
api-tests/
*.http
*.rest

# Logs and temporary files
logs/
*.log
tmp/
temp/

# OS generated files
Thumbs.db
.DS_Store
*.tmp
*.temp

# Backup files
*.backup
*.bak
*~

# Scripts that shouldn't be in production
scripts/dev_cleanup.py
scripts/setup_dev.py
{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "maven: build",
            "type": "shell",
            "command": "mvn",
            "args": ["clean", "package"],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "maven: run (local)",
            "type": "shell",
            "command": "mvn",
            "args": ["spring-boot:run", "-Dspring.profiles.active=local"],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "isBackground": true
        },
        {
            "label": "maven: test",
            "type": "shell",
            "command": "mvn",
            "args": ["test"],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        }
    ]
}

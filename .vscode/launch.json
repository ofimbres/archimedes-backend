{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "java",
            "name": "Spring Boot App (Local)",
            "request": "launch",
            "mainClass": "com.binomiaux.archimedes.app.ArchimedesApplication",
            "args": "--spring.profiles.active=local",
            "console": "integratedTerminal",
            "env": {
                "SPRING_PROFILES_ACTIVE": "local"
            }
        },
        {
            "type": "java",
            "name": "Spring Boot with DevTools (Local)",
            "request": "launch",
            "mainClass": "com.binomiaux.archimedes.app.ArchimedesApplication",
            "args": "--spring.profiles.active=local",
            "vmArgs": "-Dspring.devtools.restart.enabled=true -Dspring.devtools.livereload.enabled=true",
            "console": "integratedTerminal",
            "env": {
                "SPRING_PROFILES_ACTIVE": "local"
            }
        },
        {
            "name": "Spring Boot via Gradle (Local)",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}",
            "preLaunchTask": "gradle: bootRun (local)",
            "console": "integratedTerminal"
        }
    ]
}
###############################################################################
### 🧪 TESTING SCENARIOS
###############################################################################

### Test Error Cases

# Invalid Join Code
POST {{baseUrl}}{{apiVersion}}/enrollments/join
Content-Type: application/json

{
  "student_id": "{{studentId}}",
  "join_code": "INVALID"
}

###

# Duplicate Enrollment
POST {{baseUrl}}{{apiVersion}}/enrollments/join
Content-Type: application/json

{
  "student_id": "{{studentId}}",
  "join_code": "{{joinCode}}"
}

###

# Invalid Student ID
POST {{baseUrl}}{{apiVersion}}/enrollments/direct
Content-Type: application/json

{
  "student_id": "00000000-0000-0000-0000-000000000000",
  "course_id": "{{courseId}}",
  "enrollment_status": "active"
}

###

# Invalid Course ID
POST {{baseUrl}}{{apiVersion}}/enrollments/direct
Content-Type: application/json

{
  "student_id": "{{studentId}}",
  "course_id": "00000000-0000-0000-0000-000000000000",
  "enrollment_status": "active"
}

###

# Invalid Enrollment ID
GET {{baseUrl}}{{apiVersion}}/enrollments/00000000-0000-0000-0000-000000000000

###

# Invalid Pagination
GET {{baseUrl}}{{apiVersion}}/enrollments/student/{{studentId}}
    ?page=0
    &size=200

###############################################################################
### 📈 ENROLLMENT STATUS MANAGEMENT
###############################################################################

### Change Status to Completed
PUT {{baseUrl}}{{apiVersion}}/enrollments/{{enrollmentId}}
Content-Type: application/json

{
  "enrollment_status": "completed"
}

### Change Status to Dropped
PUT {{baseUrl}}{{apiVersion}}/enrollments/{{enrollmentId}}
Content-Type: application/json

{
  "enrollment_status": "dropped",
  "is_active": false
}

### Reactivate Dropped Enrollment
PUT {{baseUrl}}{{apiVersion}}/enrollments/{{enrollmentId}}
Content-Type: application/json

{
  "enrollment_status": "active",
  "is_active": true
}

###############################################################################
### 📝 NOTES
###############################################################################

# Enrollment Management Features:
# ✅ Enroll with join code (student self-enrollment)
# ✅ Direct enrollment (admin/teacher enrollment)
# ✅ Get enrollment by ID with student/course details
# ✅ Get student's enrollments with pagination/filtering
# ✅ Get course enrollments (teacher roster view)
# ✅ Update enrollment status and active flag
# ✅ Drop enrollment (soft delete - sets to inactive)
# ✅ Delete enrollment (hard delete - permanent removal)
# ✅ Proper error handling and validation
# ✅ Duplicate enrollment prevention
# ✅ Join code validation

# Enrollment Status Values:
# - "active": Student is currently enrolled
# - "dropped": Student dropped the course
# - "completed": Student completed the course

# Remember to:
# 1. Create courses first (use courses.http when available)
# 2. Get actual join codes from course creation
# 3. Replace {{studentId}} and {{courseId}} with real UUIDs
# 4. Use proper pagination (page >= 1, size <= 100)
# 5. Check enrollment status before operations